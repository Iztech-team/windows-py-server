# Baraka Printer Server - Windows Configuration
# Copy this to .env and adjust as needed.

# Server settings
SERVER_HOST=0.0.0.0
SERVER_PORT=3006

# Printer registry file (stores discovered printers)
PRINTER_REGISTRY=printer_registry.json

# Auto-scan network for printers on startup
SCAN_ON_STARTUP=true

# Print test receipt on each printer when server starts
TEST_PRINT_ON_STARTUP=true

# WSA Bridge (adb reverse) - enables Android WSA to reach this server
WSA_BRIDGE_ENABLED=true
WSA_ADB_PORT=58526

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
